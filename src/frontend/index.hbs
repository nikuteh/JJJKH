<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chordle 🎼</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=DM+Serif+Text&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="/styles.css" />

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/handlebars@latest/dist/handlebars.js"></script>
</head>
<body>

  <!-- Grain texture overlay -->
  <svg id="grain" xmlns="http://www.w3.org/2000/svg">
    <filter id="grainFilter">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#grainFilter)"/>
  </svg>

  <!-- App shell -->
  <div id="app">

    <!-- Top bar -->
    <header id="topbar">
      <div class="topbar-inner">
        <div class="logo">🎼 Chordle</div>
      </div>
    </header>

    <!-- Pages (only one visible at a time) -->
    <main id="main-content">

      <!-- HOME PAGE -->
      <section id="page-home" class="page active">
        <div class="page-inner">
          <div class="lesson-header card" id="lesson-header">
            <div class="vinyl-rings lesson-vinyl"></div>
            <div id="lesson-title" class="lesson-title"></div>
            <div id="lesson-meta" class="lesson-meta"></div>
            <!-- Audio player -->
            <iframe 
            style="border-radius:12px" 
            src="https://open.spotify.com/embed/track/{{SongID}}?utm_source=generator" 
            width="100%" 
            height="152" 
            frameBorder="0" 
            allowfullscreen="" 
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
            loading="lazy">
            </iframe>
          </div>

          <!-- Section tabs -->
          <div class="tabs" id="section-tabs">
          </div>

          <!-- Challenge card -->
          <div class="card challenge-card">
            <div class="label-sm">Challenge</div>
            <div class="challenge-title" id="challenge-title"></div>
            <div class="sentiment-pill" id="sentiment-pill"></div>

            <div class="label-sm" style="margin-top:18px;">Your answer</div>
            <div class="drop-zone" id="drop-zone">
              <div class="drop-placeholder" id="drop-placeholder">Tap chords to place them here</div>
            </div>
            <div class="remove-hint" id="remove-hint" style="display:none;">Tap a chord to remove it</div>

            <div class="word-bank" id="word-bank"></div>

            <div class="feedback" id="feedback" style="display:none;"></div>

            <button class="check-btn" id="check-btn" disabled>Check answer</button>
          </div>

        </div>
      </section>

    </main>

  </div>

  <script src="data.js"></script>
  <script src="app.js"></script>
</body>
</html>